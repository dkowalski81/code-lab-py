{
  "version": "2.0",
  "logging": {
	  "logLevel":{
		  "default":"Warning",
		  "Function":"Information",
		  "HostResults":"Information",
		  "Host.Aggregator":"Warning",
		  "Worker":"Warning"
	  },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensions": {
    "durableTask": {
      "hubName": "CodeLabHub"
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}
